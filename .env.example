# Скопируйте в `.env` и заполните (в т.ч. DB_PASSWORD).
# Значения ниже — для Docker Compose (DB_HOST=db, REDIS в контейнере).
# Без Docker: DB_HOST=localhost, REDIS_URL=redis://127.0.0.1:6379/0

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_HOST=db
DB_PORT=5432
DB_NAME=kgd_kpi
DB_USER=kgd_user
DB_PASSWORD=

REDIS_URL=redis://redis:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://127.0.0.1:3000

CELERY_BEAT_HOUR=6

KGD_DB_HOST=
KGD_DB_PORT=5432
KGD_DB_NAME=
KGD_DB_USER=
KGD_DB_PASSWORD=
